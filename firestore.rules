rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // iOS NotificationService direct write uyumu:
    // Sadece owner kullanıcı, yalnızca fcmTokens ve updatedAt alanlarını güncelleyebilir.
    function isOwnFcmTokenUpdate(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['fcmTokens', 'updatedAt']);
    }

    function isAppointmentOwner() {
      return resource.data.studentId == request.auth.uid ||
        resource.data.coachId == request.auth.uid;
    }

    // X-1: Frontend fallback appointment sorgularinda backend yetkilendirme
    // mantigini bypass etmeyi engellemek icin sahiplik kontrolu.
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && isAppointmentOwner();
      allow write: if false;
    }

    // N-9.1: Kullanıcı kendi profil dokümanını dinleyebilsin.
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwnFcmTokenUpdate(uid);
      allow create, delete: if false;
    }

    match /coaches/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwnFcmTokenUpdate(uid);
      allow create, delete: if false;
    }

    match /students/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwnFcmTokenUpdate(uid);
      allow create, delete: if false;
    }

    match /superadmins/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwnFcmTokenUpdate(uid);
      allow create, delete: if false;
    }

    // Varsayilan olarak tum diger koleksiyonlar client tarafina kapali.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}